# ============================================================
# Ananas Chat — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Auth -------------------------------------------------------
# Random secret for Auth.js session encryption
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me

# Canonical public URL of this app — required by Auth.js for OAuth callbacks
# Production: https://your-app.example.com  |  Local dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# Required when running behind a reverse proxy (Cloudflare Tunnel, nginx, etc.)
# Tells Auth.js to trust X-Forwarded-Proto/Host headers so it uses the correct
# HTTPS URL for cookie names and redirect generation (prevents redirect loops).
# Set to "true" in production, leave unset or "false" for local dev.
# ^
# | take this with a grain of salt, it's AI talking

AUTH_TRUST_HOST=false

# ---- Keycloak OIDC ---------------------------------------------
# Base URL of your Keycloak server (no trailing slash).
# IMPORTANT: This must match the `iss` claim in Keycloak's JWT tokens exactly.
# If Keycloak is behind HTTPS (e.g. Cloudflare Tunnel), use https:// here —
# otherwise OIDC token validation will fail with an issuer mismatch.
KEYCLOAK_URL=http://192.168.1.100:8180

# The Keycloak realm used for Ananas Chat
KEYCLOAK_REALM=ananas

# OAuth2 client created in Keycloak admin under:
# Clients → Create → Client type: OpenID Connect
# Valid redirect URI: https://your-app.example.com/api/auth/callback/keycloak
KEYCLOAK_CLIENT_ID=ananas-chat
KEYCLOAK_CLIENT_SECRET=your-client-secret

# ---- Nextcloud -------------------------------------------------
# URL of your Nextcloud instance — used for WebDAV file access.
# Nextcloud must have the user_oidc app installed and configured to
# use Keycloak as its identity provider with bearer token validation
# enabled (occ user_oidc:provider <id> --bearerValidation 1).
NEXTCLOUD_URL=https://nextcloud.example.com

# ---- Database --------------------------------------------------
# External Postgres (central infra) — point at your server IP and port
POSTGRES_URL=postgres://admin:password@192.168.1.100:5432/ananas

# ---- Vector DB -------------------------------------------------
# Qdrant runs in Docker alongside the app — keep as-is for production,
# override to http://SERVER_IP:6333 for local dev
QDRANT_URL=http://localhost:6333

# ---- AI Providers ----------------------------------------------
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Ollama — base URL of your Ollama instance (runs separately on the server)
OLLAMA_BASE_URL=http://192.168.1.100:11434

# ---- App URL ---------------------------------------------------
# Used for generating file serve URLs and metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- File Storage ----------------------------------------------
# Local directory for uploaded files (relative to project root)
UPLOADS_DIR=./uploads

# ---- Redis -----------------------------------------------------
# Required — used for resumable streams and rate limiting
# Redis runs in Docker alongside the app — keep as-is for production,
# override to redis://SERVER_IP:6379 for local dev
REDIS_URL=redis://localhost:6379
